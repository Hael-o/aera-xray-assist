{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RespirationState",
  "type": "object",
  "required": ["schema_version", "type", "device_id", "session_id", "timestamp_ms", "state"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "type": { "const": "respiration.state" },
    "device_id": { "type": "string" },
    "session_id": { "type": "string" },
    "timestamp_ms": { "type": "integer" },
    "monotonic_ms": { "type": "integer" },
    "state": {
      "enum": ["idle", "tracking", "cue_requested", "stable_breath_hold",
               "unstable", "abort", "timeout", "manual_mode"]
    },
    "signal": {
      "type": "object",
      "properties": {
        "z_mm": { "type": "number" },
        "dz_dt_mm_s": { "type": "number" },
        "d2z_dt2_mm_s2": { "type": "number" },
        "peak_phase": { "type": ["string", "null"] },
        "stable_duration_ms": { "type": "number" },
        "breathing_period_ms": { "type": ["number", "null"] }
      }
    },
    "gating": {
      "type": "object",
      "properties": {
        "window_open": { "type": "boolean" },
        "ready_to_capture": { "type": "boolean" },
        "abort": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "frame_drop_detected": { "type": "boolean" },
        "motion_artifact": { "type": "boolean" }
      }
    }
  }
}
