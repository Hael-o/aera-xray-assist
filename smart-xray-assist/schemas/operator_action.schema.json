{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperatorAction",
  "type": "object",
  "required": ["schema_version", "type", "device_id", "session_id", "timestamp_ms", "operator_id", "action"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "type": { "const": "operator.action" },
    "device_id": { "type": "string" },
    "session_id": { "type": "string" },
    "timestamp_ms": { "type": "integer" },
    "operator_id": { "type": "string" },
    "action": {
      "enum": ["start_session", "calibrate_empty_bed", "play_breath_cue",
               "approve_recommendation", "reject_recommendation",
               "switch_manual_mode", "abort", "end_session"]
    },
    "payload": { "type": "object" }
  }
}
