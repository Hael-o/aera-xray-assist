{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditEvent",
  "type": "object",
  "required": ["schema_version", "type", "audit_id", "device_id", "timestamp_ms",
               "event_category", "event_name", "severity", "actor", "payload_hash", "event_hash"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "type": { "const": "audit.event" },
    "audit_id": { "type": "string" },
    "device_id": { "type": "string" },
    "session_id": { "type": ["string", "null"] },
    "timestamp_ms": { "type": "integer" },
    "event_category": { "type": "string" },
    "event_name": { "type": "string" },
    "severity": { "enum": ["info", "warning", "error", "critical"] },
    "actor": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "enum": ["system", "operator"] },
        "id": { "type": "string" }
      }
    },
    "payload_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "prev_hash": { "type": ["string", "null"] },
    "event_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
